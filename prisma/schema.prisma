generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  STAFF
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PlanTier {
  BASIC
  PRO
  BUSINESS
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum MessageType {
  CONFIRMATION
  REMINDER
  UPDATE
  MANUAL
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  name         String?
  role         UserRole  @default(STAFF)
  businessId   String?
  business     Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([businessId])
}

model Business {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  phone         String?
  timezone      String         @default("UTC")
  status        BusinessStatus @default(TRIAL)
  billingStatus BillingStatus  @default(TRIAL)
  planTier      PlanTier       @default(BASIC)
  trialEndsAt   DateTime?
  subscription  Subscription?
  users         User[]
  customers     Customer[]
  appointments  Appointment[]
  messageLogs   MessageLog[]
  usageCounters UsageCounter[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([planTier])
}

model Subscription {
  id                     String        @id @default(cuid())
  businessId             String        @unique
  business               Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planTier               PlanTier
  billingStatus          BillingStatus @default(TRIAL)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  externalCustomerId     String?
  externalSubscriptionId String?
  cancelAtPeriodEnd      Boolean       @default(false)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

model Customer {
  id           String        @id @default(cuid())
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  notes        String?
  appointments Appointment[]
  messageLogs  MessageLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([businessId, phone])
  @@index([businessId])
}

model Appointment {
  id             String            @id @default(cuid())
  businessId     String
  business       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title          String            @default("Appointment")
  scheduledAt    DateTime
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?
  orderTotal     Decimal?          @db.Decimal(10, 2)
  orderItems     Json?
  reminderSentAt DateTime?
  confirmedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([businessId, scheduledAt])
  @@index([businessId, status])
}

model MessageLog {
  id            String           @id @default(cuid())
  businessId    String
  business      Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointmentId String?
  direction     MessageDirection @default(OUTBOUND)
  type          MessageType
  toPhone       String
  body          String
  status        MessageStatus    @default(QUEUED)
  provider      String           @default("mock")
  externalId    String?
  error         String?
  sentAt        DateTime?
  createdAt     DateTime         @default(now())

  @@index([businessId, createdAt])
}

model UsageCounter {
  id                  String   @id @default(cuid())
  businessId          String
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  periodStart         DateTime
  messagesSent        Int      @default(0)
  appointmentsCreated Int      @default(0)

  @@unique([businessId, periodStart])
}

model PaymentEvent {
  id          String    @id @default(cuid())
  businessId  String?
  provider    String    @default("mock")
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([businessId])
}
